# -----------------------------------------------------------------------------
# Apple Music Widget+ Environment Configuration Template
# Copy this file to '.env' and populate with your actual keys.
# -----------------------------------------------------------------------------

# Lyrics API Resolution Keys
GENIUS_API_KEY=your_genius_api_key_here

# Last.fm Scrobbling / Synchronization Keys
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SECRET=your_lastfm_secret_here

# Backend Capabilities Configuration
# Point to your local development backend services or staging/production URLs
BACKEND_URL=http://localhost:8000
